# ═══════════════════════════════════════════════════════════════════════════════
# .env.example — Variables de entorno para el script (COPIAR a .env y completar)
# NUNCA subas .env a git — solo este archivo .example es seguro para el repo
# ═══════════════════════════════════════════════════════════════════════════════

# Suscripciones Azure a analizar (separadas por coma, o dejar vacío para todas)
AZURE_SUBSCRIPTION_IDS=

# Directorio de salida (relativo al script)
OUTPUT_PATH=./hub-spoke-output

# Service Principal para ejecución automatizada (CI/CD)
# ARM_CLIENT_ID=
# ARM_CLIENT_SECRET=
# ARM_TENANT_ID=
